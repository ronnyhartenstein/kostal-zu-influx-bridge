# Modbus/SunSpec Quelle (Kostal)
MODBUS_HOST=kostal-wr.home
MODBUS_HOST_FALLBACK=192.168.178.53
MODBUS_PORT=1502
MODBUS_UNIT_ID=71
MODBUS_TIMEOUT=5
POLL_INTERVAL=5
MODBUS_WORD_ORDER=CDAB

# InfluxDB 1.8 Ziel (im Compose-Teststack intern)
INFLUX_HOST=influxdb
INFLUX_PORT=8086
INFLUX_DB=kostal
INFLUX_USER=kostal
INFLUX_PASS=kostalpass
INFLUX_SSL=false
INFLUX_VERIFY_SSL=true
INFLUX_MEASUREMENT=kostal_plenticore

# MQTT Ziel (im Compose-Teststack intern)
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_USER=
MQTT_PASS=
MQTT_TOPIC_PREFIX=home/kostal/plenticore
MQTT_CLIENT_ID=kostal-bridge
MQTT_TLS=false
MQTT_KEEPALIVE=60
MQTT_QOS=0
MQTT_RETAIN=false

# Bridge Verhalten
BRIDGE_CONFIG=/config/registers.yml
LOG_LEVEL=INFO
